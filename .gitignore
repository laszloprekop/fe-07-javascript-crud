# ---- OS ----
.DS_Store
.AppleDouble
.LSOverride
# Google Drive keeps creating custom folder-icon files. The real filename is
# Icon + a carriage return, so a plain `Icon` line will NOT match it.
# [[:cntrl:]] matches that trailing CR without the invisible-whitespace
# fragility of the `Icon<CR><CR>` trick, and unlike `Icon?` it will not
# swallow a real Icons/ folder. No slash => matches at any depth, forever.
Icon[[:cntrl:]]
._*
Thumbs.db
Desktop.ini

# ---- IDE / Editors ----
.idea/
.vs/
.vscode/
*.swp
*.user
*.suo

